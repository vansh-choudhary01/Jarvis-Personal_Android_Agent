[Unit]
Description=Jarvis Android automation brain
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jarvis
Group=jarvis
WorkingDirectory=/opt/jarvis/brain
EnvironmentFile=/opt/jarvis/brain/.env
ExecStart=/usr/bin/node /opt/jarvis/brain/dist/index.js
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/jarvis/brain/logs

[Install]
WantedBy=multi-user.target
